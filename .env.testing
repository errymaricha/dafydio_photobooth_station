APP_NAME=PhotoboothStation
APP_ENV=testing
APP_KEY=base64:rA3gOpMA0weAHRDtpTrvq9b2VMcU6qLv1C39p6jKxqk=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=4

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
